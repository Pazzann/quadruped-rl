            custom float urdf:dynamics:friction = 0.05
            custom float urdf:limit:effort = 5
            custom float urdf:limit:velocity = 10
        }

        def PhysicsFixedJoint "root_joint"
        {
            custom rel physics:body0 = </SimplifiedMotorForIsaac>
            custom rel physics:body1 = </SimplifiedMotorForIsaac/Geometry/base_link>
